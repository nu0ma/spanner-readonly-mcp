{
  "name": "spanner-readonly-mcp",
  "version": "1.0.0",
  "description": "Read-only MCP server for Google Cloud Spanner",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "main": "dist/index.mjs",
